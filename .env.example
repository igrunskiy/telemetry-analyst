# =============================================================================
# Telemetry Analyst — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Garage61 OAuth App ---
# Register at https://garage61.net/developer
# Set redirect URI to: http://localhost/auth/callback (or your domain)
GARAGE61_CLIENT_ID=01KKRVBKWAXVDN6NW3T8DAAPMJ
# It is ok to keep empty for localhost development
GARAGE61_CLIENT_SECRET=
GARAGE61_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Garage61 Personal Access Token (dev/testing only) ---
# If set, /auth/login will use this token and skip OAuth.
GARAGE61_PERSONAL_TOKEN=

# --- Claude API (Anthropic) ---
# Operator default key — used if user hasn't set their own
# Get one at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your-key-here

# --- Gemini API (Google AI) ---
# Operator default key — used if user hasn't set their own
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- OpenAI API ---
# Operator default key — used if user hasn't set their own
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key

# --- Logging ---
LOG_LEVEL=DEBUG

# --- Database ---
POSTGRES_USER=telemetry
POSTGRES_PASSWORD=telemetry_secret
POSTGRES_DB=telemetry_analyst
# Local dev: DATABASE_URL points to the "db" Docker service.
DATABASE_URL=postgresql+asyncpg://telemetry:telemetry_secret@db:5432/telemetry_analyst
# Prod (Cloud SQL): uncomment and set this instead, pointing to the cloudsql-proxy sidecar.
# DATABASE_URL=postgresql+asyncpg://telemetry:your-password@cloudsql-proxy:5432/telemetry_analyst

# --- Cloud SQL (prod only) ---
# Format: project:region:instance-name
CLOUD_SQL_INSTANCE=your-project:your-region:your-instance
# Path to the GCP service account JSON key on the host VM
GOOGLE_APPLICATION_CREDENTIALS=/opt/telemetry-analyst/sa-key.json

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173"]

# --- Public domain (used by Caddy for automatic HTTPS cert) ---
# Set to your domain in production, e.g. yourdomain.com
DOMAIN=yourdomain.com

# Discord OAuth
DISCORD_CLIENT_ID=1484786104493408437
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://teleme3.app/auth/discord/callback

# --- Worker Pool ---
# Max number of concurrent analysis jobs
ANALYSIS_WORKER_POOL_SIZE=5
# Seconds before the watchdog kills a stuck job
ANALYSIS_WORKER_TIMEOUT=240
# Shared .env key usage limit for users without personal model keys
DEFAULT_SHARED_REPORTS_PER_DAY=4

# --- LLM Token Limits ---
CLAUDE_MAX_TOKENS=12000
GEMINI_MAX_TOKENS=12000
OPENAI_MAX_TOKENS=12000
