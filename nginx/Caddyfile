{$DOMAIN} {
    handle /auth/* {
        reverse_proxy backend:8000
    }

    handle /api/* {
        reverse_proxy backend:8000 {
            transport http {
                read_timeout 120s
                write_timeout 120s
            }
        }
    }

    handle /admin/* {
        reverse_proxy backend:8000
    }

    handle /health {
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy frontend:80
    }
}
